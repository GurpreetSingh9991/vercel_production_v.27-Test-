# ============================================================
# TradeFlow Studio - Environment Variables
# ============================================================
# 
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# 
# ============================================================

# ─────────────────────────────────────────────────────────────
# SUPABASE (REQUIRED)
# ─────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service role key - ONLY for Netlify functions
# NEVER expose this to frontend code
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here


# ─────────────────────────────────────────────────────────────
# STRIPE (REQUIRED FOR PAYMENTS)
# ─────────────────────────────────────────────────────────────
# Get from: Stripe Dashboard → Developers → API keys

# Secret key - for Netlify functions only
STRIPE_SECRET_KEY=sk_test_your_key_here

# Webhook secret - from Stripe webhook settings
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# Price ID for Pro subscription
VITE_STRIPE_PRICE_ID=price_your_price_id

# Fallback payment link
VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/your_link


# ─────────────────────────────────────────────────────────────
# GEMINI AI (REQUIRED FOR AI FEATURES)
# ─────────────────────────────────────────────────────────────
# Get from: Google AI Studio → https://makersuite.google.com/app/apikey

VITE_GEMINI_API_KEY=your_gemini_api_key_here


# ─────────────────────────────────────────────────────────────
# OPTIONAL
# ─────────────────────────────────────────────────────────────

NODE_VERSION=18


# ─────────────────────────────────────────────────────────────
# PRODUCTION CHECKLIST
# ─────────────────────────────────────────────────────────────
# Before going live:
# 
# ✅ Use sk_live_ Stripe keys (not sk_test_)
# ✅ Rotate Supabase keys
# ✅ Configure Stripe webhook URL
# ✅ Enable RLS in Supabase
# ✅ Create trade-images storage bucket
# ✅ Test complete payment flow
# 
# ─────────────────────────────────────────────────────────────
